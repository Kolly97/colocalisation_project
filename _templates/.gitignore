# =====================================================
# Microscopy data — never commit
# =====================================================
*.tif
*.tiff
*.czi
*.lsm
*.nd2
*.lif

# =====================================================
# Pipeline outputs (generated, not source)
# =====================================================
measure_mock/
output/
qc/
masks/
*.csv

# Exception: keep small synthetic test fixtures committed
!tests/expected_outputs/*.csv
!tests/synthetic/*.tif

# =====================================================
# OS / IDE clutter
# =====================================================
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*~

# =====================================================
# Fiji / ImageJ runtime
# =====================================================
.recently_used
*.lock

# =====================================================
# Python (in case you add analysis scripts)
# =====================================================
__pycache__/
*.pyc
.venv/
.ipynb_checkpoints/
